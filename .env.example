# IBKR Flex Web Service Configuration
# Get these from IBKR Account Management

# Flex Web Service Token (not an API key!)
# Go to: Account Management → Reports → Flex Queries → Flex Web Service
# Enable Flex Web Service and copy the token
IBKR_FLEX_TOKEN=your_flex_token_here

# Flex Query ID for Positions
# Go to: Reports → Flex Queries → Create Query
# Choose "Positions" or "Account Information"
# Save and copy the Query ID
IBKR_QUERY_ID=your_query_id_here

# Discord Webhook (optional)
# Create in Discord: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK=your_discord_webhook_url_here

# OpenClaw Gateway Configuration
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here
OPENCLAW_SESSION=main
